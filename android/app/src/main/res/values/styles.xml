<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Le fond de fenêtre est noir : si jamais le système affiche un
             flash bref avant le splash React, il sera invisible (même couleur
             que le splash custom #0a0a0a). -->
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <!-- Launch theme : on n'utilise plus Theme.SplashScreen (qui ajoutait un
         splash natif explicite avec le logo). Le seul splash visible est
         maintenant celui que React rend dans SplashScreen.jsx. -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar" />
</resources>
